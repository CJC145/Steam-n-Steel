            # Temperature-based fire colour (600–1300°C)
            def fire_colour_from_temp(temp: float):
                t = (temp - 600) / 700
                t = max(0.0, min(1.0, t))

                gradient = [
                    (80, 0, 0),        # deep red
                    (160, 30, 0),      # red-orange
                    (230, 90, 0),      # bright orange
                    (255, 170, 40),    # orange-yellow
                    (255, 240, 180),   # yellow-white
                ]

                idx = int(t * (len(gradient) - 1))
                frac = (t * (len(gradient) - 1)) - idx

                c1 = gradient[idx]
                c2 = gradient[min(idx + 1, len(gradient) - 1)]

                return (
                    int(c1[0] + (c2[0] - c1[0]) * frac),
                    int(c1[1] + (c2[1] - c1[1]) * frac),
                    int(c1[2] + (c2[2] - c1[2]) * frac),
                )

            color = fire_colour_from_temp(self.fire_temp)

            fuel_rect = pygame.Rect(
                self.opening_center[0] - self.opening_radius,
                self.opening_center[1] + self.opening_radius - f_h,
                self.opening_radius * 2,
