import pygame
import math
import time

# --- Speed Gauge Class ---
class SpeedGauge:
    def __init__(self, x, y, scale=1.0, max_speed=100):
        self.x, self.y, self.scale = x, y, scale
        self.max_speed = max_speed
        self.angle_min, self.angle_max = 150, 390
        self.speed = 0
        self.color_bg = (207, 197, 157)
        self.color_border_outer = (89, 86, 74)
        self.color_border_inner = (46, 44, 38)
        self.color_text = (79, 76, 66)
        self.color_needle = (255, 0, 0)
        self.recalculate_scale(self.x, self.y, self.scale)

    def recalculate_scale(self, x, y, scale):
        self.x, self.y, self.scale = x, y, scale
        self.radius = 250 * self.scale
        self.font = pygame.font.SysFont(None, int(40 * self.scale))
        self.big_font = pygame.font.SysFont(None, int(60 * self.scale))

    def _get_coords(self, angle_deg, distance):
        angle_rad = math.radians(angle_deg)
        return (self.x + math.cos(angle_rad) * (distance * self.scale),
                self.y + math.sin(angle_rad) * (distance * self.scale))

    def _lerp_angle(self, speed):
        return self.angle_min + (speed / self.max_speed) * (self.angle_max - self.angle_min)

    def update(self, current_speed):
        self.speed = max(0, min(current_speed, self.max_speed))

    def draw(self, surface):
        pygame.draw.circle(surface, self.color_bg, (self.x, self.y), self.radius)
        pygame.draw.circle(surface, self.color_border_outer, (self.x, self.y), self.radius, max(1, int(8 * self.scale)))
        pygame.draw.circle(surface, self.color_border_inner, (self.x, self.y), self.radius, max(1, int(10 * self.scale)))

        for s in range(0, self.max_speed + 1, 10):
            angle = self._lerp_angle(s)
            p1, p2 = self._get_coords(angle, 210), self._get_coords(angle, 240)
            pygame.draw.line(surface, self.color_text, p1, p2, max(1, int(4 * self.scale)))
            lx, ly = self._get_coords(angle, 180)
            label = (
                self.big_font.render(str(s), True, self.color_text)
                if s in (20, 40, 60, 80, 100)
                else self.font.render(str(s), True, self.color_text)
            )
            surface.blit(label, label.get_rect(center=(lx, ly)))

        needle_angle = self._lerp_angle(self.speed)
        tip = self._get_coords(needle_angle, 220)
        pygame.draw.line(surface, self.color_needle, (self.x, self.y), tip, max(1, int(6 * self.scale)))
        pygame.draw.circle(surface, self.color_needle, (self.x, self.y), max(1, int(12 * self.scale)))


# --- Boiler Pressure Gauge Class ---

class BoilerPressureGauge:
    def __init__(self, x, y, scale=1.0, max_pressure=320):
        self.x, self.y, self.scale = x, y, scale
        self.max_pressure = max_pressure
        self.angle_min, self.angle_max = 150, 390
        self.pressure = 0
        
        # Brass/Bronze aesthetic colors
        self.color_bg = (220, 215, 190)
        self.color_border_outer = (184, 134, 11)  # Dark Goldenrod / Brass
        self.color_border_inner = (139, 101, 8)   
        self.color_text = (50, 50, 40)
        self.color_needle = (30, 30, 30)
        self.color_redline = (200, 40, 40)
        
        self.recalculate_scale(self.x, self.y, self.scale)

    def recalculate_scale(self, x, y, scale):
        self.x, self.y, self.scale = x, y, scale
        self.radius = 200 * self.scale
        self.font = pygame.font.SysFont(None, int(30 * self.scale))
        self.big_font = pygame.font.SysFont(None, int(45 * self.scale))

    def _get_coords(self, angle_deg, distance):
        angle_rad = math.radians(angle_deg)
        return (self.x + math.cos(angle_rad) * (distance * self.scale),
                self.y + math.sin(angle_rad) * (distance * self.scale))

    def _lerp_angle(self, pressure):
        # Your provided linear interpolation formula
        return self.angle_min + (pressure / self.max_pressure) * (self.angle_max - self.angle_min)

    def update(self, current_pressure):
        self.pressure = max(0, min(current_pressure, self.max_pressure))

    def draw(self, surface):
        pygame.draw.circle(surface, self.color_bg, (self.x, self.y), self.radius)
        pygame.draw.circle(surface, self.color_border_outer, (self.x, self.y), self.radius, max(1, int(12 * self.scale)))
        pygame.draw.circle(surface, self.color_border_inner, (self.x, self.y), self.radius - int(12 * self.scale), max(1, int(4 * self.scale)))
        
        # Draw PSI Label
        psi_label = self.font.render("PSI", True, self.color_text)
        surface.blit(psi_label, psi_label.get_rect(center=(self.x, self.y + (60 * self.scale))))

        # Draw the Red Line area (200 to 240)
        rect = pygame.Rect(self.x - self.radius + int(20*self.scale), self.y - self.radius + int(20*self.scale), 
                           (self.radius*2) - int(40*self.scale), (self.radius*2) - int(40*self.scale))
        start_rad = math.radians(360 - self._lerp_angle(240)) # Pygame arcs draw counter-clockwise
        end_rad = math.radians(360 - self._lerp_angle(200))
        pygame.draw.arc(surface, self.color_redline, rect, start_rad, end_rad, int(15 * self.scale))

        for p in range(0, self.max_pressure + 1, 20):
            angle = self._lerp_angle(p)
            tick_len = 170 if p % 40 == 0 else 180
            p1, p2 = self._get_coords(angle, tick_len), self._get_coords(angle, 190)
            pygame.draw.line(surface, self.color_text, p1, p2, max(1, int(3 * self.scale)))
            
            if p % 40 == 0:
                lx, ly = self._get_coords(angle, 145)
                label = self.big_font.render(str(p), True, self.color_text)
                surface.blit(label, label.get_rect(center=(lx, ly)))
        
        needle_angle = self._lerp_angle(self.pressure)
        tip = self._get_coords(needle_angle, 185)
        tail = self._get_coords(needle_angle + 180, 40) # Counter-weight on needle
        pygame.draw.line(surface, self.color_needle, tail, tip, max(1, int(6 * self.scale)))
        pygame.draw.circle(surface, self.color_needle, (self.x, self.y), max(1, int(15 * self.scale)))


