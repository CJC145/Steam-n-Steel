        label_surf = self.font.render("Smoke colour indicates combustion completeness", True, (200, 200, 200))
        surface.blit(label_surf, (self.box_rect.left + 10, self.box_rect.bottom + 10))

        if self.smoke_colour is not None:
            rect = pygame.Rect(self.box_rect.left + 10, self.box_rect.bottom + 35,
