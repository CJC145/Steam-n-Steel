        pygame.draw.rect(surface, (30, 30, 30), self.right_door_rect, int(2 * self.scale))

        # ------------------------------------------------------------
        # 7. Lever Mechanism & Linkages
        # ------------------------------------------------------------
        pygame.draw.line(surface, (10, 10, 10),
                        (self.lever_track_x, self.lever_y),
                        (self.lever_track_x + self.lever_track_width, self.lever_y),
